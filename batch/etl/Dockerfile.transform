FROM golang:1.25 AS builder
WORKDIR /app
COPY batch/etl/go.mod batch/etl/go.sum ./
RUN go mod download
COPY batch/etl/ ./
RUN CGO_ENABLED=0 go build -o pechka-etl .

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/pechka-etl /usr/local/bin/pechka-etl

ENTRYPOINT ["/usr/local/bin/pechka-etl", "transform"]
